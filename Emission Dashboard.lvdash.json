{
  "datasets": [
    {
      "name": "a3c093a2",
      "displayName": "Location Data",
      "queryLines": [
        "select latitude, longitude,  `GHG emissions mtons CO2e` as emission\r\n",
        "from emissions.default.emissions_data"
      ]
    },
    {
      "name": "dfe0e5ee",
      "displayName": "Emissions per Person",
      "queryLines": [
        "select county_state_name, \r\n",
        "       population, \r\n",
        "       cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) / nullif(population, 0) as emissions_per_person\r\n",
        "from emissions_data\r\n",
        "order by emissions_per_person desc\r\n"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "0119e003",
      "displayName": "Total Emissions Per State",
      "queryLines": [
        "select state_abbr, \r\n",
        "       sum(cast(replace(`GHG emissions mtons CO2e`, ',', '') as double)) as total_emissions\r\n",
        "from emissions_data\r\n",
        "group by state_abbr\r\n",
        "order by total_emissions desc\r\n",
        "limit 10"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "8b97de7f",
      "displayName": "County Shaming",
      "queryLines": [
        "select county_state_name, \r\n",
        "       population, \r\n",
        "       cast(replace(`GHG emissions mtons CO2e`, ',', '') as double)  as Total_Emissions\r\n",
        "from emissions_data\r\n",
        "order by Total_Emissions desc\r\n",
        "limit 10"
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
